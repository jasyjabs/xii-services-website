<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Mobile Logistics &amp; Contact - XII Services LLC</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13daec",
                        "background-light": "#f6f8f8",
                        "background-dark": "#102022",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
<style>
        body {
            font-family: 'Inter', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display">
<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
<!-- Header -->
<header class="sticky top-0 z-50 flex items-center bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md p-4 border-b border-slate-200 dark:border-primary/20 justify-between">
<div class="flex items-center gap-3">
<div class="bg-primary/20 p-2 rounded-lg">
<span class="material-symbols-outlined text-primary">flight_takeoff</span>
</div>
<h2 class="text-slate-900 dark:text-slate-100 text-lg font-bold leading-tight tracking-tight">XII Services LLC</h2>
</div>
<button class="text-slate-900 dark:text-slate-100 p-2 rounded-lg active:bg-slate-200 dark:active:bg-primary/10 transition-colors">
<span class="material-symbols-outlined">menu</span>
</button>
</header>
<main class="flex-1 pb-24">
<!-- Hero Title -->
<div class="px-4 pt-6 pb-2">
<h1 class="text-slate-900 dark:text-slate-100 text-3xl font-bold leading-tight">Contact &amp; Quality</h1>
<p class="text-slate-600 dark:text-slate-400 mt-2">Aviation parts and logistics services tailored for excellence across the continent.</p>
</div>
<!-- Reach Section (Map) -->
<section class="px-4 py-4">
<div class="flex items-center justify-between mb-3">
<h3 class="text-slate-900 dark:text-slate-100 text-lg font-bold">Our Reach in Africa</h3>
<span class="text-primary text-xs font-medium bg-primary/10 px-2 py-1 rounded">Interactive Map</span>
</div>
<div class="relative w-full aspect-[4/3] bg-slate-200 dark:bg-slate-800 rounded-xl overflow-hidden border border-slate-200 dark:border-primary/20 shadow-lg">
<div class="absolute inset-0 bg-cover bg-center opacity-80" data-alt="Map of Africa continent highlighting major aviation hubs" data-location="Africa" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCiO3cyksYk4zauRTuMtT4DrS58ydPXTpXSOSE85uX5-X-1NUTvdHUHb3z-Wvl2EPGo3vUfRmLB8q3nNqNGFrhwRKbQk8O1EeTBPBf0GZn6Eg8vy1pRsd9ifcKZ4nLwqUokof4imEbCzse_jMSP9Ln3_jthIbsk__ppFoC3j8A9oTap95jl81OLank9UyOzFjIAlE5JwlpXIbTajGNAS2XNJYThfVwtelvqezC_3AK9dgAXM6JyIGrDCB9Y70kebMqBm9hwUd9-pZI');">
</div>
<!-- Map Markers -->
<div class="absolute top-[55%] left-[45%] group">
<div class="relative flex items-center justify-center">
<div class="absolute h-6 w-6 rounded-full bg-primary animate-ping opacity-75"></div>
<div class="h-4 w-4 rounded-full bg-primary border-2 border-white dark:border-background-dark shadow-sm"></div>
<div class="absolute bottom-6 bg-slate-900/90 text-white text-[10px] py-1 px-2 rounded backdrop-blur-sm whitespace-nowrap">Lagos Hub</div>
</div>
</div>
<div class="absolute top-[60%] left-[35%] group">
<div class="relative flex items-center justify-center">
<div class="h-4 w-4 rounded-full bg-primary border-2 border-white dark:border-background-dark shadow-sm"></div>
<div class="absolute bottom-6 bg-slate-900/90 text-white text-[10px] py-1 px-2 rounded backdrop-blur-sm whitespace-nowrap">Accra Hub</div>
</div>
</div>
<!-- Zoom Controls (Visual) -->
<div class="absolute right-3 bottom-3 flex flex-col gap-1">
<button class="h-10 w-10 bg-white/90 dark:bg-slate-900/90 rounded-lg flex items-center justify-center shadow-md border border-slate-200 dark:border-primary/20">
<span class="material-symbols-outlined text-slate-700 dark:text-slate-300">add</span>
</button>
<button class="h-10 w-10 bg-white/90 dark:bg-slate-900/90 rounded-lg flex items-center justify-center shadow-md border border-slate-200 dark:border-primary/20">
<span class="material-symbols-outlined text-slate-700 dark:text-slate-300">remove</span>
</button>
</div>
</div>
<p class="text-slate-500 dark:text-slate-400 text-xs mt-3 italic">Pinch to zoom, tap markers for details.</p>
</section>
<!-- Quality Assurance Section -->
<section class="px-4 py-6 bg-slate-100 dark:bg-primary/5 mt-4">
<h3 class="text-slate-900 dark:text-slate-100 text-lg font-bold mb-4">Quality Assurance</h3>
<div class="grid grid-cols-2 gap-3">
<div class="bg-white dark:bg-background-dark p-4 rounded-xl border border-slate-200 dark:border-primary/10 shadow-sm flex flex-col items-center text-center">
<span class="material-symbols-outlined text-primary text-3xl mb-2">verified_user</span>
<p class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">FAA Certified</p>
</div>
<div class="bg-white dark:bg-background-dark p-4 rounded-xl border border-slate-200 dark:border-primary/10 shadow-sm flex flex-col items-center text-center">
<span class="material-symbols-outlined text-primary text-3xl mb-2">new_releases</span>
<p class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">EASA Compliant</p>
</div>
<div class="bg-white dark:bg-background-dark p-4 rounded-xl border border-slate-200 dark:border-primary/10 shadow-sm flex flex-col items-center text-center">
<span class="material-symbols-outlined text-primary text-3xl mb-2">workspace_premium</span>
<p class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">ISO 9001:2015</p>
</div>
<div class="bg-white dark:bg-background-dark p-4 rounded-xl border border-slate-200 dark:border-primary/10 shadow-sm flex flex-col items-center text-center">
<span class="material-symbols-outlined text-primary text-3xl mb-2">high_quality</span>
<p class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">AS9120 Rev B</p>
</div>
</div>
</section>
<!-- Contact Form Section -->
<section class="px-4 py-8">
<h3 class="text-slate-900 dark:text-slate-100 text-xl font-bold mb-6">Request Support</h3>
<form class="space-y-6">
<div>
<label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2" for="name">Full Name</label>
<input class="w-full h-14 bg-white dark:bg-slate-800/50 border border-slate-200 dark:border-primary/20 rounded-xl px-4 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none" id="name" placeholder="John Doe" type="text"/>
</div>
<div>
<label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2" for="email">Corporate Email</label>
<input class="w-full h-14 bg-white dark:bg-slate-800/50 border border-slate-200 dark:border-primary/20 rounded-xl px-4 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none" id="email" placeholder="john@airline.com" type="email"/>
</div>
<div>
<label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2" for="service">Service Type</label>
<select class="w-full h-14 bg-white dark:bg-slate-800/50 border border-slate-200 dark:border-primary/20 rounded-xl px-4 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none appearance-none" id="service">
<option>Parts Procurement</option>
<option>Logistics &amp; Shipping</option>
<option>Quality Consulting</option>
<option>AOG Emergency</option>
</select>
</div>
<div>
<label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2" for="message">Requirement Details</label>
<textarea class="w-full bg-white dark:bg-slate-800/50 border border-slate-200 dark:border-primary/20 rounded-xl p-4 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none" id="message" placeholder="Describe your parts or logistics needs..." rows="4"></textarea>
</div>
<button class="w-full h-14 bg-primary text-background-dark font-bold text-lg rounded-xl shadow-lg shadow-primary/20 active:scale-[0.98] transition-transform" type="submit">
                        Send Request
                    </button>
</form>
</section>
</main>
<!-- Bottom Navigation Bar -->
<nav class="fixed bottom-0 left-0 right-0 z-50 bg-white/95 dark:bg-background-dark/95 backdrop-blur-md border-t border-slate-200 dark:border-primary/20 px-4 pb-6 pt-2">
<div class="flex items-center justify-around">
<a class="flex flex-col items-center gap-1 text-slate-400 dark:text-slate-500" href="#">
<span class="material-symbols-outlined text-[24px]">home</span>
<span class="text-[10px] font-medium">Home</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 dark:text-slate-500" href="#">
<span class="material-symbols-outlined text-[24px]">settings_accessibility</span>
<span class="text-[10px] font-medium">Services</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 dark:text-slate-500" href="#">
<span class="material-symbols-outlined text-[24px]">public</span>
<span class="text-[10px] font-medium">Reach</span>
</a>
<a class="flex flex-col items-center gap-1 text-primary" href="#">
<span class="material-symbols-outlined text-[24px] font-fill">mail</span>
<span class="text-[10px] font-medium">Contact</span>
</a>
</div>
</nav>
</div>
</body></html>