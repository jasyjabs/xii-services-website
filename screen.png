<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Logistics &amp; Quality Preview - XII Services LLC</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13daec",
                        "background-light": "#f6f8f8",
                        "background-dark": "#102022",
                        "accent-gold": "#FFD700",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                },
            },
        }
    </script>
<style>
        .gold-emboss {
            background: linear-gradient(145deg, #ffd700, #b8860b);
            box-shadow: 0 4px 15px rgba(184, 134, 11, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .neon-input:focus {
            box-shadow: 0 0 10px rgba(19, 218, 236, 0.5);
            border-color: #13daec;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased">
<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
<!-- Header -->
<header class="sticky top-0 z-50 flex items-center bg-background-light/90 dark:bg-background-dark/90 backdrop-blur-md px-4 py-3 justify-between border-b border-primary/10">
<div class="text-slate-900 dark:text-slate-100 flex size-10 shrink-0 items-center justify-center">
<span class="material-symbols-outlined">menu</span>
</div>
<h2 class="text-slate-900 dark:text-slate-100 text-lg font-bold leading-tight tracking-tight flex-1 text-center">Contact &amp; Quality</h2>
<div class="flex w-10 items-center justify-end">
<button class="flex items-center justify-center rounded-lg h-10 w-10 bg-primary/10 text-primary">
<span class="material-symbols-outlined">person</span>
</button>
</div>
</header>
<main class="flex-1 pb-24">
<!-- Hero Section -->
<div class="@container">
<div class="@[480px]:p-4">
<div class="flex min-h-[420px] flex-col gap-6 bg-cover bg-center bg-no-repeat @[480px]:rounded-xl items-start justify-end px-6 pb-12 relative overflow-hidden" data-alt="Professional aviation team in a modern sunlit hangar" style="background-image: linear-gradient(to top, rgba(16, 32, 34, 0.9) 0%, rgba(16, 32, 34, 0.2) 60%, rgba(0,0,0,0) 100%), url('https://lh3.googleusercontent.com/aida-public/AB6AXuDsHmp8XpcMIjUK0igANvBuApyGLhwF-NLejVx2PD6djzYvvY-vqTSsBWmdbja9cTjs9AiRYlJPPq1o3zFcuy7lFILEDjXXDV0ku2V3PzQrAuICoCvWcKuU2K1u_NDqA25jkQ_KHMbQ58gj0RhRNPgom-ikJG380VR8_B4zcnEON3M_G9AVQk5SwJqsvQzjgYK1VrpukOb4Otej3tvv3k0YUnQd3awrZUJdsuZM_vPFfWJiAjO4REEgT-_XE_ODx7cylPC4Rh_Bd8E');">
<div class="flex flex-col gap-3 relative z-10">
<span class="bg-primary px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-background-dark w-fit">Aviation Excellence</span>
<h1 class="text-white text-4xl font-black leading-tight tracking-tight">
                                Quality Without Compromise
                            </h1>
<p class="text-slate-200 text-sm leading-relaxed max-w-xs">
                                Serving West Africa with world-class logistics and FAA-certified parts from our Dakar and Lagos hubs.
                            </p>
</div>
<button class="flex min-w-[140px] cursor-pointer items-center justify-center rounded-lg h-12 px-6 bg-primary text-background-dark text-sm font-bold leading-normal tracking-wide transition-transform active:scale-95">
                            Get a Quote
                        </button>
</div>
</div>
</div>
<!-- Quality Badges Section -->
<section class="px-4 py-8">
<h3 class="text-slate-900 dark:text-slate-100 text-xl font-bold mb-6 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">verified_user</span>
                    Certified Standards
                </h3>
<div class="grid grid-cols-3 gap-4">
<div class="flex flex-col items-center gap-2">
<div class="gold-emboss size-16 rounded-full flex items-center justify-center text-white">
<span class="material-symbols-outlined text-3xl">workspace_premium</span>
</div>
<span class="text-[10px] font-bold text-center uppercase">FAA Part 145</span>
</div>
<div class="flex flex-col items-center gap-2">
<div class="gold-emboss size-16 rounded-full flex items-center justify-center text-white">
<span class="material-symbols-outlined text-3xl">award_star</span>
</div>
<span class="text-[10px] font-bold text-center uppercase">ISO 9001:2015</span>
</div>
<div class="flex flex-col items-center gap-2">
<div class="gold-emboss size-16 rounded-full flex items-center justify-center text-white">
<span class="material-symbols-outlined text-3xl">verified</span>
</div>
<span class="text-[10px] font-bold text-center uppercase">ASA Accredited</span>
</div>
</div>
</section>
<!-- Reach Section -->
<section class="px-4 py-6 bg-slate-900 text-white rounded-t-3xl mt-4">
<div class="flex items-center justify-between mb-4">
<h3 class="text-xl font-bold">Our Reach in Africa</h3>
<span class="text-primary text-xs font-medium px-2 py-1 bg-primary/10 rounded">Live Network</span>
</div>
<div class="relative w-full aspect-video bg-slate-800 rounded-xl overflow-hidden border border-slate-700" style="background-image: radial-gradient(circle at center, #1a3a3d 0%, #0d1a1b 100%);">
<div class="absolute inset-0 opacity-40 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
<!-- High-contrast map representation -->
<div class="absolute inset-0 flex items-center justify-center" data-alt="Modern dark map of West Africa with glowing teal connection points" data-location="West Africa" style="">
<span class="material-symbols-outlined text-primary/20 text-9xl">public</span>
<!-- Glowing Teal Hubs -->
<div class="absolute top-1/2 left-1/3 size-3 bg-primary rounded-full shadow-[0_0_15px_#13daec]"></div>
<div class="absolute top-[60%] left-[45%] size-3 bg-primary rounded-full shadow-[0_0_15px_#13daec]"></div>
<div class="absolute top-[55%] left-[55%] size-3 bg-primary rounded-full shadow-[0_0_15px_#13daec]"></div>
<div class="absolute top-[48%] left-[25%] size-3 bg-primary rounded-full shadow-[0_0_15px_#13daec]"></div>
</div>
<div class="absolute bottom-3 left-3 flex flex-col gap-1">
<div class="flex items-center gap-2 text-[10px]"><span class="size-2 bg-primary rounded-full"></span> Lagos Hub</div>
<div class="flex items-center gap-2 text-[10px]"><span class="size-2 bg-primary rounded-full"></span> Accra Station</div>
<div class="flex items-center gap-2 text-[10px]"><span class="size-2 bg-primary rounded-full"></span> Dakar HQ</div>
</div>
</div>
</section>
<!-- Contact Form -->
<section class="px-4 py-8">
<h3 class="text-slate-900 dark:text-slate-100 text-xl font-bold mb-6">Inquiry &amp; Support</h3>
<form class="space-y-4">
<div>
<label class="block text-xs font-bold uppercase text-slate-500 mb-1 ml-1">Full Name</label>
<input class="w-full bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg px-4 py-3 text-sm focus:ring-primary focus:border-primary neon-input outline-none" placeholder="John Doe" type="text"/>
</div>
<div>
<label class="block text-xs font-bold uppercase text-slate-500 mb-1 ml-1">Corporate Email</label>
<input class="w-full bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg px-4 py-3 text-sm focus:ring-primary focus:border-primary neon-input outline-none" placeholder="john@airline.com" type="email"/>
</div>
<div>
<label class="block text-xs font-bold uppercase text-slate-500 mb-1 ml-1">Message</label>
<textarea class="w-full bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg px-4 py-3 text-sm focus:ring-primary focus:border-primary neon-input outline-none" placeholder="Specify parts or service requirements..." rows="4"></textarea>
</div>
<button class="w-full bg-primary text-background-dark font-bold py-4 rounded-xl shadow-lg shadow-primary/20 flex items-center justify-center gap-2" type="submit">
<span class="material-symbols-outlined">send</span>
                        Submit Request
                    </button>
</form>
</section>
</main>
<!-- Bottom Navigation Bar -->
<nav class="fixed bottom-0 left-0 right-0 z-50 flex border-t border-slate-200 dark:border-slate-800 bg-background-light/95 dark:bg-background-dark/95 backdrop-blur-md px-4 pb-6 pt-2">
<a class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-400" href="#">
<span class="material-symbols-outlined">home</span>
<p class="text-[10px] font-medium uppercase tracking-tighter">Home</p>
</a>
<a class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-400" href="#">
<span class="material-symbols-outlined">public</span>
<p class="text-[10px] font-medium uppercase tracking-tighter">Network</p>
</a>
<a class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-400" href="#">
<span class="material-symbols-outlined">verified</span>
<p class="text-[10px] font-medium uppercase tracking-tighter">Quality</p>
</a>
<a class="flex flex-1 flex-col items-center justify-center gap-1 text-primary" href="#">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">mail</span>
<p class="text-[10px] font-medium uppercase tracking-tighter">Contact</p>
</a>
</nav>
</div>
</body></html>